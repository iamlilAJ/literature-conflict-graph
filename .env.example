# Optional: used only for LLM claim extraction.
OPENAI_API_KEY=

# Optional: OpenAI-compatible endpoint, e.g. a local gateway or LiteLLM server.
AIGRAPH_BASE_URL=

# Optional: model id used by the LLM extractor.
AIGRAPH_MODEL=gpt-5.4

# Optional: prefer /v1/responses or /v1/chat/completions.
AIGRAPH_LLM_ENDPOINT=responses

# Optional: model reasoning effort for supported providers.
AIGRAPH_REASONING_EFFORT=high

# Optional: parallel per-paper extraction calls.
AIGRAPH_EXTRACT_CONCURRENCY=2

# Optional: pre-reader before final claim extraction: off | heuristic | mini
AIGRAPH_READER_MODE=mini

# Optional: mini-model used by the paper reader.
AIGRAPH_READER_MODEL=gpt-5.4-mini

# Optional: max grounded candidate sentences per paper passed downstream.
AIGRAPH_READER_MAX_CANDIDATES=6

# Optional: heuristic sentence pool size before mini reranking.
AIGRAPH_READER_PREFILTER_SENTENCES=16

# Optional: contact email for OpenAlex polite pool.
AIGRAPH_MAILTO=
