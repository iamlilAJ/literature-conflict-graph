# Install with:
#   crontab automation/cron/crontab.example
#
# Before enabling nightly fixes, make sure:
# - repo .env contains AIGRAPH_CODEX_FIX_COMMAND if you want Codex-driven fixes
# - git push works from this machine
# - gh auth status is already logged in

SHELL=/bin/bash
PATH=/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin

15 * * * * cd /Users/liuanjie/PycharmProjects/hypothesis_generation && ./automation/bin/hourly_loop.sh >> /Users/liuanjie/PycharmProjects/hypothesis_generation/automation/logs/hourly_loop.log 2>&1
40 */2 * * * cd /Users/liuanjie/PycharmProjects/hypothesis_generation && ./automation/bin/critic_loop.sh >> /Users/liuanjie/PycharmProjects/hypothesis_generation/automation/logs/critic_loop.log 2>&1
10 3 * * * cd /Users/liuanjie/PycharmProjects/hypothesis_generation && ./automation/bin/nightly_fix.sh >> /Users/liuanjie/PycharmProjects/hypothesis_generation/automation/logs/nightly_fix.log 2>&1
